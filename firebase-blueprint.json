{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "A user's profile containing their wishlist and cart.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "wishlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of product IDs in the user's wishlist."
        },
        "cart": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of product IDs in the user's cart."
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profiles."
    }
  }
}
