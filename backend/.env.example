# Backend environment variables for local development
# Do not store real secret values in version control.
# Set these in a private .env file or your deployment environment.

# Server configuration
PORT=4000
HOST=localhost
NODE_ENV=development

# MongoDB connection
# Default local database for the fashionweb store.
# Supported variable names: MONGODB_URI, MONGO_URI, DATABASE_URL, MONGO_URL
MONGODB_URI=mongodb://localhost:27017/fashionweb

# JWT secret used for signing authenticatiion tokens
JWT_SECRET=your_jwt_secret_key_change_in_production

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API domain for CSP
API_DOMAIN=https://api.example.com

# ============================================
# TWILIO SMS CONFIGURATION - FOR OTP
# ============================================
# Get from: https://console.twilio.com/
# Leave all blank if you want to use mock OTP (logs to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ============================================
# FACEBOOK OAUTH CONFIGURATION
# ============================================
# Get from: https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ============================================
# OPTIONAL - REDIS (for caching/rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# API & CORS CONFIGURATION
# ============================================
API_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173
